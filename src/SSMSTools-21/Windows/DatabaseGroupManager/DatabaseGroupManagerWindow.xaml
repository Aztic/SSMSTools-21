<Window x:Class="SSMSTools_21.Windows.DatabaseGroupManager.DatabaseGroupManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:SSMSTools_21.Windows.DatabaseGroupManager"
        Height="340" Width="460"
        ResizeMode="NoResize"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        ContentRendered="Window_ContentRendered">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Name field -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock FontWeight="SemiBold" Margin="0,0,0,4"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">Name</TextBlock>
            <ui:TextBox Text="{Binding DatabaseGroupName, Mode=TwoWay}" PlaceholderText="Enter group name" />
        </StackPanel>

        <!-- Select All Checkbox -->
        <CheckBox Grid.Row="1"
                  Content="Select All"
                  IsChecked="{Binding IsAllSelected, Mode=TwoWay}"
                  Margin="0,0,0,8"/>

        <!-- Scrollable List of databases -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
            <ItemsControl ItemsSource="{Binding Databases}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Name}"
                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                  Margin="0,2,0,2">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox" BasedOn="{StaticResource {x:Type CheckBox}}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button Content="Cancel" Width="90" Margin="0,0,8,0" Click="CancelButton_Click" Appearance="Secondary" />
            <ui:Button Content="Save" Width="90" Click="SaveButton_Click" Appearance="Secondary" />
        </StackPanel>
    </Grid>

</Window>